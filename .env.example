# ==========================================
# PROJECT TRISHUL - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to '.env' and populate the values below.

# --- DhanHQ API Credentials ---
# Required for connecting to the Nifty Futures market data pipelines
TRISHUL_AUTH_TOKEN=your_dhanhq_auth_token_here
TRISHUL_CLIENT_ID=your_dhanhq_client_id_here

# --- Supabase Database Configuration ---
# Required for logging breakout signals to the PostgreSQL database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# --- Discord Webhook ---
# Required for routing trading signals and breakout alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
